# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only. NEVER expose to the client. Used by admin API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of admin emails (gates the /admin panel).
# Must also be seeded into the admin_emails table (supabase/seed.sql).
ADMIN_EMAILS=prajjit2009@gmail.com
