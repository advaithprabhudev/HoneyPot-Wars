# Required for the real scan agent
OPENAI_API_KEY=sk-proj-...

# Optional — only needed for the arena game (leaderboard, rounds persistence)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Arena engine (leave as 'local' unless you also have ANTHROPIC_API_KEY)
ARENA_ENGINE=local
ARENA_MODE=ondemand
