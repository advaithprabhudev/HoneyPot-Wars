# Required for the real scan pipeline AND the arena LLM engine (scanner, 4 defender agents, referee, detector)
# Leave unset to run the arena in deterministic local mode
OPENAI_API_KEY=sk-proj-...

# Required for leaderboard persistence and cross-restart novelty tracking (Supabase)
# Leave unset to use in-memory only — leaderboard endpoint will return 500
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info

# Arena engine — 'local' (deterministic, no API key needed) or 'llm_openai' (requires OPENAI_API_KEY)
ARENA_ENGINE=local
ARENA_MODE=ondemand

# Optional: custom temp directory for ZIP/GitHub repo extraction (defaults to os.tmpdir())
# SCAN_TMP_DIR=/tmp/honeypot-scans

# Optional: Redis URL — only needed when ARENA_MODE=continuous
# REDIS_URL=redis://localhost:6379
